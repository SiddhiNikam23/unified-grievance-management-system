# MongoDB Connection
MONGO_URI=mongodb://localhost:27017

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-key-change-this-in-production

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Session Configuration
SESSION_SECRET=your-session-secret-change-this
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true

# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Social Complaint Listener
SOCIAL_LISTENER_ENABLED=true
SOCIAL_SCAN_INTERVAL_MINUTES=3

# Optional: Comma-separated JSON feed URLs for Instagram-like post ingestion
# Each feed URL should return either an array of posts or { "posts": [...] }
# where every post has id/shortcode, username/user, caption/text, permalink/url, timestamp
INSTAGRAM_FEED_URLS=

# Notification Engine Configuration
# SMTP (User + Admin Email Notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Government Grievance Cell <no-reply@nagrikconnect.gov.in>"

# Admin alert email list for HIGH/CRITICAL complaints
ADMIN_ALERT_EMAILS=

# Telegram alerts (HIGH/CRITICAL only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=

# Slack alerts (HIGH/CRITICAL only)
SLACK_WEBHOOK_URL=

# IMPORTANT: Copy this file to .env and change all secrets!
